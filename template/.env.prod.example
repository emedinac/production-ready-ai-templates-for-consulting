# Production Environment Variables
# Copy this file to .env.prod and fill in your values

# AWS Configuration (for S3 remote storage)
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1
AWS_DEFAULT_REGION=us-east-1

# PostgreSQL Configuration (for local database storage)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=your-db-user
POSTGRES_PASSWORD=your-secure-db-password
POSTGRES_DB=your-database-name

# MLflow Configuration
MLFLOW_TRACKING_URI=https://your-mlflow-server.com
MLFLOW_S3_ENDPOINT_URL=https://s3.amazonaws.com

# Database Configuration (for MLflow)
POSTGRES_PASSWORD=your-secure-password

# Grafana Configuration
GRAFANA_PASSWORD=your-admin-password

# Model Configuration
MODEL_VERSION=latest

# DVC Remote URLs (choose based on your storage backend)
# For S3:
DVC_STORAGE_REMOTE=s3://your-production-bucket/dvc-cache
DVC_MODELS_REMOTE=s3://your-models-bucket/models
DVC_DATA_REMOTE=s3://your-data-bucket/data

# For PostgreSQL (uncomment and update if using PostgreSQL):
# DVC_STORAGE_REMOTE=postgresql://your-db-user:your-secure-db-password@localhost:5432/dvc_cache
# DVC_MODELS_REMOTE=postgresql://your-db-user:your-secure-db-password@localhost:5432/models
# DVC_DATA_REMOTE=postgresql://your-db-user:your-secure-db-password@localhost:5432/data

# Application Configuration
ENVIRONMENT=production
LOG_LEVEL=INFO

# Optional: Redis Configuration
REDIS_URL=redis://redis:6379

# Optional: Monitoring
PROMETHEUS_PUSHGATEWAY_URL=http://prometheus-pushgateway:9091